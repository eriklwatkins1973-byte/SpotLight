import { NextResponse } from 'next/server';

const API_KEY = process.env.TWELVELABS_API_KEY;
const INDEX_ID = process.env.TWELVELABS_DEFAULT_INDEX_ID;

export async function POST(req: Request) {
  try {
    const { query } = await req.json();

    // 1. Call Twelve Labs Any-to-Video Search
    const response = await fetch('https://api.twelvelabs.io/v1.3/search', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': API_KEY!,
      },
      body: JSON.stringify({
        index_id: INDEX_ID,
        query_text: query,
        search_options: ['visual', 'conversation'], // Searches both images and audio/transcript
        conversation_option: 'semantic',
      }),
    });

    const data = await response.json();

    // 2. Format the results for the UI
    // Twelve Labs returns 'data' as an array of match segments
    const formattedResults = data.data.map((match: any) => ({
      videoId: match.video_id,
      score: match.score, // Relevance ranking
      start: match.start, // Start timestamp in seconds
      end: match.end,     // End timestamp in seconds
      thumbnail: match.thumbnail_url,
      metadata: match.metadata,
    }));

    return NextResponse.json(formattedResults);
  } catch (error) {
    console.error('Search failed:', error);
    return NextResponse.json({ error: 'Failed to search video library' }, { status: 500 });
  }
}
